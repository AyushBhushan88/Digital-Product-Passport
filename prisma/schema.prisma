generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model BatteryPassport {
  id               String   @id @default(uuid()) @db.Uuid
  externalId       String   @unique
  manufacturerId   String
  productionDate   DateTime
  model            String
  carbonFootprint  Decimal  @db.Decimal(10, 2)
  metadata         Json     @default("{}")
  contentHash      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([externalId])
  @@index([manufacturerId])
}

model RawEvent {
  id        String   @id @default(uuid()) @db.Uuid
  type      String   // e.g., 'SUPPLIER_DATA'
  sector    String   // e.g., 'FASHION', 'ELECTRONICS', 'BATTERY'
  payload   Json
  status    String   // 'PENDING', 'PROCESSED', 'FAILED'
  jobId     String?  // BullMQ Job ID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([jobId])
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  action     String   // e.g., 'INGESTION', 'TWIN_UPDATE'
  entityType String   // e.g., 'RawEvent', 'BatteryPassport'
  entityId   String
  actor      String
  hash       String   // SHA-256 fingerprint
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([hash])
}
